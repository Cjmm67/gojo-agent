# =============================================================
# Gojo-sensei Environment Variables
# Copy this to .env.local and fill in your values
# =============================================================

# Anthropic API Key — get from console.anthropic.com
# NEVER commit the real key to git
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Max's 4-digit PIN to access the chat (change this!)
MAX_PIN=1234

# Parent password to access the dashboard at /parent (change this!)
PARENT_PASSWORD=parent123

# Daily chat time limit in minutes (default: 15)
DAILY_LIMIT_MINUTES=15

# Parent alert email (for future production use)
PARENT_EMAIL=

# Upstash Redis (auto-injected when you connect KV store on Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=
